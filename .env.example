# Copy to .env and fill in. Never commit real secrets.

# --- Core ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me
JWT_SIGNING_KEY=change-me-too
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# --- Database / Redis ---
DATABASE_URL=postgres://playstudy:playstudy@localhost:5432/playstudy
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
# In dev, run generation inline (no worker needed). Set False to use Celery.
CELERY_TASK_ALWAYS_EAGER=True

# --- AI (server-only — never ships in the app) ---
# Provider: deepseek | local | gemini
LLM_PROVIDER=deepseek
LLM_TEMPERATURE=0.4
LLM_MAX_OUTPUT_TOKENS=4096

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Local model (Ollama / vLLM / LM Studio — OpenAI-compatible)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=not-needed
LOCAL_LLM_MODEL=llama3.1

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Limits ---
FREE_GENERATION_LIMIT=2
MAX_UPLOAD_BYTES=20971520

# --- Storage (S3). Leave bucket blank to use local media in dev. ---
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Social auth ---
GOOGLE_OAUTH_CLIENT_IDS=
APPLE_BUNDLE_IDS=

# --- CORS (web/debug clients) ---
CORS_ALLOWED_ORIGINS=

# --- Observability (prod) ---
SENTRY_DSN=
ENVIRONMENT=production
